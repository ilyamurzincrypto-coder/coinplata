# =============================================================================
# CoinPlata — local env template
# =============================================================================
# 1. Copy to `.env.local` for local dev (git-ignored).
# 2. Paste the same values into Vercel → Project → Settings → Environment Variables.
#
# Both keys are safe to ship in client bundles (anon key is public by design,
# RLS enforces data access on server).
# =============================================================================

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# =============================================================================
# Feature flags — production has v2 ledger active (cutover completed 2026-05-10)
# =============================================================================
# v2 ledger / DealForm v2 — production direction. Cutover landed 2026-05-10
# after Phase 1 (adapter coverage + validateTx + 10 wrappers) and Phase 2
# (backfill 13 opening journal entries) shipped. Legacy public.deals/
# account_movements frozen via ledger.freeze_legacy_tables().
#
# For local dev: set both to `true` to mirror production behaviour. Set either
# to `false` to debug against legacy ExchangeForm + rpcCreateDeal.
#
# (The temporary VITE_FORCE_V2 kill-switch was removed in the cutover commit;
# now both flags read directly from env without a code-level override.)
# =============================================================================
VITE_USE_NEW_DEAL_FORM=true
VITE_USE_NEW_LEDGER=true
