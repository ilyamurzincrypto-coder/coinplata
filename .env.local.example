# =============================================================================
# CoinPlata — local env template
# =============================================================================
# 1. Copy to `.env.local` for local dev (git-ignored).
# 2. Paste the same values into Vercel → Project → Settings → Environment Variables.
#
# Both keys are safe to ship in client bundles (anon key is public by design,
# RLS enforces data access on server).
# =============================================================================

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# =============================================================================
# Feature flags — now resolved in CODE with defaults; NOT required in env.
# =============================================================================
# - VITE_USE_NEW_DEAL_FORM — IGNORED. CashierPage hard-codes `false` (legacy
#   ExchangeForm is the deal form, by user request).
# - VITE_USE_NEW_LEDGER — defaults to TRUE in src/lib/newLedger.js (v2 ledger
#   is the product; legacy public.deals/account_movements frozen). You do NOT
#   need to set it anywhere. Set it to `false` ONLY for an emergency rollback
#   to the legacy RPCs — and even then see docs/CUTOVER_RUNBOOK.md, the legacy
#   tables are frozen. Vite inlines this at build time → a change needs a
#   redeploy to take effect.
# =============================================================================
# VITE_USE_NEW_LEDGER=false   # uncomment only to roll back to legacy ledger
