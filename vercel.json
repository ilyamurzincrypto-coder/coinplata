{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cashdesk/sync", "schedule": "* * * * *" },
    { "path": "/api/rapira/sync", "schedule": "*/2 * * * *" },
    { "path": "/api/tolunay/sync", "schedule": "*/10 * * * *" },
    { "path": "/api/aegis/poll", "schedule": "*/10 * * * *" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
